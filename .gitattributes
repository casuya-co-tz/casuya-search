# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# OS files
.DS_Store export-ignore
Thumbs.db export-ignore

# IDE files
.vscode export-ignore
.idea export-ignore
*.swp export-ignore
*.swo export-ignore
